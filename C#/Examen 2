#include "stdafx.h"
#include <stdio.h>

/* Aquest programa demana que introdueixis un nombre qualsevol, i et diu si és múltiple de 2, si és múltiple de 3, si és múltiple de 2 i 3 a la vegada, o si no ho és de cap dels dos */

int main ()
{
	int nombre;

	printf("Introdueix un nombre enter: ");
	scanf_s("%d", &nombre);
	if ((nombre % 2 == 0)&(nombre % 3 == 0)) printf("El nombre %d es multiple de 2 i 3",nombre);
	else if ((nombre % 2 == 0)&(nombre % 3 != 0)) printf("El nombre %d es multiple de 2",nombre);
	else if ((nombre % 2 != 0)&(nombre % 3 == 0)) printf("El nombre %d es multiple de 3",nombre);
	else printf("El nombre %d no es multiple ni de 2 ni de 3",nombre);
}


