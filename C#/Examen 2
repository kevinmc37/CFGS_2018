#include "stdafx.h"
#include <stdio.h>
#define limit 21

/* Aquest programa et demana que introdueixis la temperatura actual. Si la temperatura és inferior a 21 graus, sortirà un missatge dient que aturis l’aire condicionat. Si la temperatura és major o igual a 21 graus, el missatge dirà que activis l’aire condicionat */

int main ()
{
	int temp;

	printf("Introdueix la temperatura actual: ");
	scanf_s("%d", &temp);
	if (temp >= limit) printf("Activa l’aire condicionat.\n\n");
	else printf("Atura l’aire condicionat.\n\n");
}


