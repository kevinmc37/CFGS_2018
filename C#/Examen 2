#include "stdafx.h"
#include <stdio.h>

/* Aquest programa et demana que introdueixis dos nombres, i et diu quin és el més gran dels dos, o si són iguals */

int main ()
{
	float nombre1,nombre2;

	printf("Introdueix un nombre: ");
	scanf_s("%f", &nombre1);
	printf("Introdueix un segon nombre: ");
	scanf_s("%f", &nombre2);
	if (nombre1 > nombre2) printf("El nombre %f es mes gran que el nombre %f.\n\n", nombre1, nombre2);
	else if (nombre2 > nombre1) printf("El nombre %f es mes gran que el nombre %f.\n\n", nombre2, nombre1);
	else printf("Els dos nombres son iguals.\n\n");
}


