#include "stdafx.h"
#include <stdio.h>
#define inici 9
#define final 17

/* Aquest programa et demana que introdueixis l’hora actual, que només pot comprendre valors entre 0 i 23. Si l’hora introduïda està fora d’aquest valors, surt un missatge d’error. Si l’hora és entre les 9 i les 17 (no inclòs), surt un missatge dient que és hora de treball. Si es qualsevol altra hora vàlida, el missatge dirà "Temps lliure" */

int main ()
{
	int hora;

	printf("Introdueix l’hora actual (de 0 a 23): ");
	scanf_s("%d", &hora);
	if ((hora < 0)|(hora > 23)) printf("Error. L’hora no es correcta.\n\n");
	else if ((hora >= inici)&(hora < final)) printf("Es hora de treball.\n\n");
	else printf("Temps lliure.\n\n");
}
